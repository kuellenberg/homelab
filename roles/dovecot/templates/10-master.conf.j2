service auth {
  unix_listener {{ dovecot_auth_socket_path }} {
    mode = {{ dovecot_auth_socket_mode }}
    user = {{ dovecot_auth_socket_user }}
    group = {{ dovecot_auth_socket_group }}
  }
}

service lmtp {
  unix_listener {{ dovecot_lmtp_socket_path }} {
    mode = {{ dovecot_lmtp_socket_mode }}
    user = {{ dovecot_lmtp_socket_user }}
    group = {{ dovecot_lmtp_socket_group }}
  }
}