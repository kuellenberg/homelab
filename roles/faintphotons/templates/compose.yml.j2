services:
  faintphotons:
    image: nginx:alpine
    container_name: faintphotons
    restart: unless-stopped
    volumes:
      - {{ faintphotons_.root }}/dist:/usr/share/nginx/html:ro
      # optional eigene nginx config:
      # - /opt/astro-site/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ proxy_network }}
      - traefik.http.routers.faintphotons.rule=Host(`faintphotons.com`)
      - traefik.http.routers.faintphotons.entrypoints=https
      - traefik.http.routers.faintphotons.tls.certresolver=letsencrypt
      - traefik.http.services.faintphotons.loadbalancer.server.port=80

        # www + .de Domains abfangen
      - traefik.http.routers.redirect.rule=Host(`www.faintphotons.com`) || Host(`faintphotons.de`) || Host(`www.faintphotons.de`)
      - traefik.http.routers.redirect.entrypoints=https
      - traefik.http.routers.redirect.tls.certresolver=letsencrypt

      # Middleware: redirect auf canonical domain
      - traefik.http.middlewares.redirect-to-main.redirectregex.regex=^https?://(www\.)?faintphotons\.(com|de)(.*)
      - traefik.http.middlewares.redirect-to-main.redirectregex.replacement=https://faintphotons.com$3
      - traefik.http.middlewares.redirect-to-main.redirectregex.permanent=true

      - traefik.http.routers.redirect.middlewares=redirect-to-main

      - traefik.http.routers.http-catchall.rule=HostRegexp(`{host:.+}`)
      - traefik.http.routers.http-catchall.entrypoints=http
      - traefik.http.routers.http-catchall.middlewares=redirect-to-https

      - traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https
    networks:
      - {{ proxy_network }}

networks:
  {{ proxy_network }}:
    external: true